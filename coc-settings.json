{
  "coc.preferences.extensionUpdateCheck": "weekly",
  "coc.source.vimtex.enable": true,
  "python.analysis.typeCheckingMode": "off",
  "coc.preferences.formatOnSaveFiletypes": [
    "css",
    "markdown",
    "javascript",
    "graphql",
    "html",
    "yaml",
    "json",
    "python"
  ],
  // explorer
  "explorer.width": 30,
  "explorer.icon.enableNerdfont": true,
  "explorer.previewAction.onHover": false,
  "explorer.keyMappings.global": {
    "<cr>": [
      "expandable?",
      "expand",
      "open"
    ],
    "v": "open:vsplit"
  },
  // python config
  "python.pythonPath": "/home/arc/.virtual_envs/pynvim/bin/python",
  "python.formatting.provider": "black",
  "python.formatting.blackPath": "/home/arc/.virtual_envs/pynvim/bin/black",
  "python.linting.pylintEnabled": true,
  "python.linting.pylintPath": "/home/arc/.virtual_envs/pynvim/bin/pylint",
  "python.linting.pylintUseMinimalCheckers": false,
  "codeLens.enable": true,
  "python.linting.pylintArgs": [
    "--load-plugins",
    "--rcfile",
    "~/.pylintrc",
    "-d",
    "C0411"
  ],
  "python.venvPath": "/home/arc/.virtual_envs",
  "snippets.userSnippetsDirectory": "~/.config/nvim/snips",
  "suggest.enablePreview": true,
  //html config
  "html.enable": true,
  "html.filetypes": [
    "html",
    "handlebars",
    "htmldjango",
    "blade"
  ],
  "html.format.enable": true,
  "html.suggest.html5": true,
  "html.autoClosingTags": true,
  // eslint config
  "eslint.enable": true,
  "eslint.run": "onType",
  "eslint.autoFix": true,
  // go config
  "languageserver": {
    "golang": {
      "command": "gopls",
      "rootPatterns": [
        "go.mod",
        ".vim/",
        ".git/",
        ".hg/"
      ],
      "filetypes": [
        "go"
      ]
    }
  }
}
