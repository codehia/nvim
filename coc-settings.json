{
  "coc.preferences.extensionUpdateCheck": "weekly",
  "coc.source.vimtex.enable": true,
  "python.analysis.typeCheckingMode": "off",
  "coc.preferences.formatOnSaveFiletypes": [
    "css",
    "markdown",
    "javascript",
    "graphql",
    "html",
    "yaml",
    "json",
    "python"
  ],
  // explorer
  "explorer.width": 30,
  "explorer.icon.enableNerdfont": true,
  "explorer.previewAction.onHover": false,
  "explorer.keyMappings.global": {
    "<cr>": [
      "expandable?",
      "expand",
      "open"
    ],
    "v": "open:vsplit"
  },
  // python config
  "python.venvPath": "/home/codehia/.virtual_envs/pyenv",
  "python.pythonPath": "/home/codehia/.virtual_envs/pyenv/bin/python",
  "python.formatting.autopep8Args": ["--max-line-length=120", "--experimental", "--aggressive", "--aggressive"],
  "python.linting.flake8Enabled":true,
  "python.linting.flake8Path": "/home/codehia/.virtual_envs/pyenv/bin/flake8",
  "python.analysis.autoImportCompletions": true,
  "python.linting.lintOnSave": true,
  "codeLens.enable": true,
  "python.linting.pylintArgs": [
    "--load-plugins",
    "--rcfile",
    "~/.pylintrc",
    "-d",
    "C0411"
  ],
  "snippets.userSnippetsDirectory": "~/.config/nvim/snips",
  "suggest.enablePreview": true,
  //html config
  "html.enable": true,
  "html.filetypes": [
    "html",
    "handlebars",
    "htmldjango",
    "blade"
  ],
  "html.format.enable": true,
  "html.suggest.html5": true,
  "html.autoClosingTags": true,
  // eslint config
  "eslint.enable": true,
  "eslint.run": "onType",
  "eslint.autoFix": true,
  // go config
  "languageserver": {
    "golang": {
      "command": "gopls",
      "rootPatterns": [
        "go.mod",
        ".vim/",
        ".git/",
        ".hg/"
      ],
      "filetypes": [
        "go"
      ]
    }
  },
  "cSpell.userWords": [
    "ASGI",
    "Bitonic",
    "Coversations",
    "Flockjay",
    "Hoverable",
    "Subarray",
    "Subarrays",
    "Upvotes",
    "asana",
    "bcrypt",
    "calendly",
    "cfiocfio",
    "christoomey",
    "convo",
    "dari",
    "dateutil",
    "fastapi",
    "fieldtitle",
    "fjapi",
    "gamify",
    "gmail",
    "gsuite",
    "isalpha",
    "isnumeric",
    "itertools",
    "jsonify",
    "latinx",
    "linkedin",
    "linkify",
    "nargs",
    "neoclide",
    "onboarded",
    "opps",
    "pydantic",
    "pylist",
    "pynvim",
    "pyright",
    "pytz",
    "sheerun",
    "simplejwt",
    "snakify",
    "soteria",
    "starlette",
    "trello",
    "uszipcode",
    "uvicorn",
    "vals",
    "venv"
  ]
}
